---
import Layout from '~/layouts/Layout.astro';
import BalanceForm from '~/components/BalanceForm';
import { requireUserId } from '~/lib/session.server';
import { getBalance } from '~/models/balances.server';
import { getAccounts } from '~/models/accounts.server';

try {
  var userId = await requireUserId(Astro.cookies, Astro.url.pathname);
  const { balanceId } = Astro.params;

  if (!balanceId) {
    return Astro.redirect('/balances');
  }

  var balance = await getBalance({ id: balanceId, userId });
  var accounts = await getAccounts({ userId, archived: false });
} catch (error: any) {
  if (error.message.startsWith('REDIRECT:')) {
    return Astro.redirect(error.message.replace('REDIRECT:', ''));
  }
  throw error;
}
---

<Layout title="Edit Balance">
  <h1 class="pb-4 text-3xl">Edit balance</h1>
  <BalanceForm balance={balance} accounts={accounts} client:load />
</Layout>
